import { Inject, Injectable, Logger } from '@nestjs/common';
import { ConfigType } from '@nestjs/config';
import { AmqpConnection } from '@golevelup/nestjs-rabbitmq';
import rabbitmqConfig from '../config/rabbitmq.config';

@Injectable()
export class MessagesService {
  private readonly logger = new Logger(MessagesService.name);

  constructor(
    private readonly amqpConnection: AmqpConnection,
    @Inject(rabbitmqConfig.KEY)
    private readonly config: ConfigType<typeof rabbitmqConfig>,
  ) {}

  async publish(payload: Record<string, unknown>): Promise<void> {
    const published = await this.amqpConnection.publish(
      this.config.exchange,
      this.config.routingKey,
      payload,
    );

    if (!published) {
      this.logger.warn(
        `Message not confirmed by broker (exchange=${this.config.exchange}, routingKey=${this.config.routingKey})`,
      );
    }
  }
}

